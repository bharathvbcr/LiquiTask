{
  "name": "liquitask",
  "productName": "LiquiTask",
  "private": true,
  "version": "1.0.2",
  "description": "A premium Kanban task management desktop app with a stunning liquid glass aesthetic",
  "author": {
    "name": "LiquidTask",
    "email": "support@liquitask.com"
  },
  "type": "module",
  "scripts": {
    "dev": "node scripts/electrobun.cjs dev",
    "dev:web": "vite",
    "dev:electrobun": "node scripts/electrobun.cjs dev",
    "dev:electrobun:ui": "vite",
    "build": "npm run build:electrobun",
    "build:web": "vite build",
    "build:electrobun": "npm run build:web && node scripts/electrobun.cjs build",
    "preview": "vite preview",
    "package": "node scripts/electrobun.cjs build --env=stable",
    "package:electrobun": "node scripts/electrobun.cjs build --env=stable",
    "test": "vitest",
    "test:run": "vitest --run",
    "test:coverage": "vitest --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\""
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-markdown": "9.0.1",
    "remark-gfm": "4.0.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.20",
    "electrobun": "1.15.1",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.47",
    "prettier": "^3.2.0",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.8.2",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "rollup": "4.59.0"
  }
}
