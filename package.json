{
  "name": "liquitask",
  "productName": "LiquiTask",
  "private": true,
  "version": "2.2.0",
  "description": "A premium Kanban task management desktop app with a stunning liquid glass aesthetic",
  "author": {
    "name": "LiquidTask",
    "email": "support@liquitask.com"
  },
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:web\" \"npm run dev:electron\"",
    "dev:web": "vite",
    "dev:electron": "wait-on tcp:3000 && tsc -p electron/tsconfig.json && cross-env NODE_ENV=development electron .",
    "build": "npm run build:web && npm run build:electron && electron-builder",
    "build:web": "vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest --run",
    "test:coverage": "vitest --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\""
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/generative-ai": "0.21.0",
    "@tanstack/react-virtual": "^3.13.23",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-markdown": "9.0.1",
    "remark-gfm": "4.0.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^39.8.1",
    "electron-builder": "^26.8.1",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.47",
    "prettier": "^3.2.0",
    "sharp": "^0.34.5",
    "svgo": "^4.0.1",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.8.2",
    "vite": "^7.3.1",
    "vite-plugin-image-optimizer": "^2.0.3",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18",
    "wait-on": "^8.0.2"
  },
  "overrides": {
    "rollup": "4.59.0"
  },
  "build": {
    "appId": "com.liquitask.app",
    "productName": "LiquiTask",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    }
  }
}
