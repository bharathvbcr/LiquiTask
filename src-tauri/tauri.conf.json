{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LiquiTask",
  "version": "2.5.0",
  "identifier": "com.liquitask.app",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "devUrl": "http://localhost:4000",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "LiquiTask",
        "label": "main",
        "width": 1400,
        "height": 900,
        "x": 80,
        "y": 80,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "visible": false,
        "center": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; object-src 'none'; base-uri 'self'; frame-src 'none'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost ws://localhost:4000 http://localhost:4000 http://localhost:* http://127.0.0.1:* http://[::1]:* https://generativelanguage.googleapis.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "category": "Productivity",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
