{
  "$schema": "https://schema.tauri.app/config/2",
  "app": {
    "windows": [
      {
        "title": "LiquiTask",
        "label": "main",
        "width": 1400,
        "height": 900,
        "x": 80,
        "y": 80,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": false,
        "visible": false,
        "center": false
      }
    ]
  },
  "bundle": {
    "targets": ["app", "dmg"],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": "-",
      "entitlements": "entitlements.plist"
    }
  }
}
